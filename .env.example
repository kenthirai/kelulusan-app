# Environment Variables untuk Frontend (Vite)
# Ganti dengan Google Client ID yang Anda dapatkan dari Google Cloud Console
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"

# Environment Variables untuk Backend (Hono / Cloudflare Workers)
# Kunci rahasia untuk menandatangani sesi admin (Gunakan string acak yang panjang)
JWT_SECRET="ganti_dengan_rahasia_jwt_anda"

# Jika Anda membutuhkan validasi sisi server untuk Google Login (opsional tergantung implementasi)
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Daftar email admin yang diizinkan (pisahkan dengan koma jika lebih dari satu)
ADMIN_EMAILS="email_admin_anda@gmail.com,email_admin_lain@gmail.com"
